{
  "name": "idml-view",
  "displayName": "IDML View",
  "description": "Browse the contents of Adobe InDesign IDML (UCF/ZIP) files as a file tree.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:idml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "idml-view.openArchive",
        "title": "IDML View: Open IDML Archive..."
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "idml-view.openArchive",
          "when": "resourceExtname == .idml",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test:unit": "npm run compile && node --test \"dist/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "typescript": "^5.5.0",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "yauzl": "^3.4.0"
  }
}
